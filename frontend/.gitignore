# Frontend-specific overrides (root .gitignore covers most rules)

# Dependencies — never commit
node_modules/

# Build output
dist/
dist-ssr/
.vite/

# Environment secrets — NEVER commit
.env
.env.*
!.env.example
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
