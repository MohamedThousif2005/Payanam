# =============================================================
#  PAYANAM — Root .gitignore
#  Spring Boot (Java 17 / Maven) + Vite / React (Node.js)
# =============================================================


# ─────────────────────────────────────────────
#  PRIVACY & SECRETS  ← never commit these
# ─────────────────────────────────────────────
.env
.env.*
!.env.example          # keep the template, not the real file
*.env
application-local.yml
application-local.properties
application-secret.yml
application-secret.properties
**/src/main/resources/application-prod.yml
**/src/main/resources/application-prod.properties
secrets/
credentials/
*.pem
*.key
*.p12
*.jks
*.pfx
*.cer
*.crt
service-account*.json
firebase*.json
google-credentials*.json
aws-credentials
.aws/


# ─────────────────────────────────────────────
#  LOGS & RUNTIME ARTIFACTS
# ─────────────────────────────────────────────
logs/
*.log
*.log.*
startup.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
hs_err_pid*
replay_pid*


# ─────────────────────────────────────────────
#  JAVA / MAVEN  (backend)
# ─────────────────────────────────────────────
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
**/.mvn/wrapper/maven-wrapper.jar
*.class
*.jar
*.war
*.ear
*.nar
!**/src/main/**/target/
!**/src/test/**/target/
!**/src/main/**/build/
!**/src/test/**/build/


# ─────────────────────────────────────────────
#  NODE / VITE  (frontend)
# ─────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
*.local


# ─────────────────────────────────────────────
#  OS FILES
# ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/


# ─────────────────────────────────────────────
#  IDE / EDITORS
# ─────────────────────────────────────────────

## VS Code
.vscode/*
!.vscode/extensions.json   # share recommended extensions
!.vscode/settings.json     # share workspace settings (non-sensitive)

## IntelliJ IDEA / JetBrains
.idea/
*.iws
*.iml
*.ipr

## Eclipse / STS
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache

## NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/

## Vim / Emacs / other editors
*.swp
*.swo
*.sw?
*~
\#*\#
.#*


# ─────────────────────────────────────────────
#  TESTING & COVERAGE
# ─────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/
test-results/
surefire-reports/


# ─────────────────────────────────────────────
#  MISC GENERATED / TEMP FILES
# ─────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
*.patch
*.rej
